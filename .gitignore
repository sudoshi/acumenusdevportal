# Generated per host by scripts/generate-build-info.sh on every sync.
# Contains hostname + git SHAs; not meant to be a source-of-truth artifact.
public/build-info.json

# Asset snapshots regenerated by scripts/sync-assets.sh from the local
# Parthenon checkout. Total size ~325 MB and changes constantly — committing
# them would balloon the repo and produce noisy diffs. Re-run sync-assets.sh
# on any host that needs to serve the portal.
public/graphify/
public/schemaspy/
public/screenshots/
public/reference/

# Local SchemaSpy install (downloaded by scripts/generate-schemaspy.sh).
tools/

# Editor / OS noise
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/
*~

# Environment / secrets — keep out by default; commit *.example only.
.env
.env.*
!.env.example
